# ---------------------------------------------------------------------------
# n8n_agent environment variables
# Copy this file to `.env` and fill in the blanks.
# Reference: docs/L0-system/D0-3_Dev_Ops.md §2 Environment Variables
#
# Sections:
#   1. n8n target
#   2. OpenAI-compatible inference endpoint (LLM + embeddings)
#   3. Models                        (chat + embedding + per-stage overrides)
#   4. LLM sampling & timeouts
#   5. Agent graph control
#   6. RAG / vector store
#   7. Observability
#   8. Frontend
# Anything not set here picks up the default baked into `app/config.py`.
# ---------------------------------------------------------------------------

# ---------- 1. n8n --------------------------------------------------------
# n8n REST API the backend will call from the host machine.
N8N_URL=http://localhost:5678

# n8n API key — mint in the n8n UI:
#   1. `docker compose up -d` then open http://localhost:5678
#   2. Create the owner account (first-run wizard)
#   3. Settings -> n8n API -> "Create an API key"
#   4. Copy the key and paste it below (sent as `X-N8N-API-KEY` header)
N8N_API_KEY=

# ---------- 2. OpenAI-compatible inference endpoint ----------------------
# Works with whatever serves both the chat and embeddings models:
# OpenAI, vllm `--served-model-name`, LiteLLM, OpenRouter, Ollama-OpenAI, etc.
# Examples:
#   OpenAI:         https://api.openai.com/v1
#   vllm (local):   http://localhost:8000/v1
#   vllm (docker):  http://host.docker.internal:8000/v1
OPENAI_BASE_URL=http://localhost:8000/v1

# API key sent as `Authorization: Bearer <key>`. vllm accepts any non-empty
# string; use your real key for OpenAI.
OPENAI_API_KEY=EMPTY

# Embeddings-only endpoint. Empty → falls back to OPENAI_BASE_URL (R-CONF-01).
# Use when your embedding model lives on a different server (e.g. Ollama).
# EMBED_BASE_URL=http://localhost:11434/v1

# Optional: separate API key for the embeddings endpoint. Empty → reuse
# OPENAI_API_KEY (R-CONF-02). Set when EMBED_BASE_URL points to a different
# provider that requires its own credentials (e.g. OpenAI / Voyage / Cohere).
# EMBED_API_KEY=

# ---------- 3. Models -----------------------------------------------------
# Default chat + embedding model ids — MUST match what the OpenAI-compat
# server is actually serving (`curl $OPENAI_BASE_URL/models` to list).
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBED_MODEL=BAAI/bge-m3

# Embedding prompt profile: auto | embeddinggemma | bge | openai | none.
# `auto` infers from EMBED_MODEL. See docs/L1-components/C1-2_RAG.md §7.
EMBED_PROMPT_PROFILE=auto

# Optional per-stage chat model overrides. Empty = fall back to LLM_MODEL.
# Common pattern: small/cheap model for planner+builder, stronger model for
# fix-retry (fix is a harder task), optional cheap critic.
# PLANNER_MODEL=
# BUILDER_MODEL=
# FIX_MODEL=Qwen/Qwen2.5-14B-Instruct
# CRITIC_MODEL=

# ---------- 4. LLM sampling & timeouts -----------------------------------
# Default temperature for chat stages.
LLM_TEMPERATURE=0.2

# HTTP timeout (seconds) per LLM invocation. Raise for slower remote models.
LLM_TIMEOUT_SEC=180

# Wall-clock budget for a full /chat pipeline (plan→build→validate→fix→deploy).
# Raise this alongside LLM_TIMEOUT_SEC if stages are slow.
CHAT_REQUEST_TIMEOUT_SEC=180

# Per-stage temperature overrides. Fix + critic default to 0.0 for
# determinism; uncomment to override. Planner/builder fall back to
# LLM_TEMPERATURE when unset.
# PLANNER_TEMPERATURE=
# BUILDER_TEMPERATURE=
# FIX_TEMPERATURE=0.0
# CRITIC_TEMPERATURE=0.0

# ---------- 5. Agent graph control ---------------------------------------
# Max fix/rebuild attempts after a validation failure.
AGENT_MAX_RETRIES=2

# Rough char budget for the builder/fix prompt. Above this the builder
# drops trailing node definitions before calling the LLM. Raise if the
# chosen chat model has a large context window.
BUILDER_PROMPT_CHAR_BUDGET=12000

# ---------- 6. RAG / vector store ----------------------------------------
# Vector store backend. Today: `chroma`. Extension points (qdrant, pinecone,
# weaviate, …) live in `backend/app/rag/vector_store.py`.
VECTOR_STORE_BACKEND=chroma

# ChromaDB persistent directory (gitignored) when backend=chroma.
CHROMA_PATH=./.chroma

# Similarity metric used by the vector store: cosine | l2 | ip.
# Chroma maps this onto the collection's `hnsw:space`.
RAG_DISTANCE_METRIC=cosine

# Top-k hits for planner discovery / builder fallback detailed search.
RAG_DISCOVERY_K=8
RAG_DETAILED_K=3

# Batch size for embedding calls during ingest.
EMBED_BATCH_SIZE=32

# ---------- 7. Observability ---------------------------------------------
# Backend log level (DEBUG | INFO | WARNING | ERROR).
LOG_LEVEL=INFO

# ---------- 8. Frontend --------------------------------------------------
# Backend URL for the Streamlit frontend.
BACKEND_URL=http://localhost:8000
